# ============================================================
# SonarQube Auto-Fix Agent — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# App
SECRET_KEY=change-me-to-a-random-64-char-hex-string
DATABASE_URL=sqlite+aiosqlite:///./app.db
ENVIRONMENT=development

# SonarQube (hosted)
SONARQUBE_URL=https://sonarqube.ai-launch-pad.com
SONARQUBE_TOKEN=your-sonarqube-token-here

# GitHub (default PAT — users can also provide per-repo PATs in UI)
GITHUB_DEFAULT_PAT=

# ============================================================
# LLM Provider API Keys — add only the ones you use
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Default agent model assignments (optional — can be set via Settings UI)
# Format: provider_name/model_id  e.g. openai/gpt-4o
SCANNER_AGENT_MODEL=openai/gpt-4o
FIXER_AGENT_MODEL=openai/gpt-4o
REVIEWER_AGENT_MODEL=openai/gpt-4o-mini
REPORTER_AGENT_MODEL=openai/gpt-4o-mini
