# ============================================================
# SonarAgent — Backend Environment Variables
# ------------------------------------------------------------
# Copy this file to backend/.env and fill in your values.
# Most values can also be configured at runtime from the
# Settings → SonarQube and Settings → LLM Providers UI.
# ============================================================

# ─── App ──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
DATABASE_URL=sqlite+aiosqlite:///./app.db
ENVIRONMENT=development
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── SonarQube ────────────────────────────────────────────────
# URL of your SonarQube server (Community / Developer / Enterprise)
SONARQUBE_URL=https://sonarqube.example.com

# Personal Access Token (User Token) generated from
# SonarQube → My Account → Security → Generate Tokens.
# Required scopes: "Browse" + "Execute Analysis" on the target projects.
SONARQUBE_TOKEN=

# ─── GitHub ───────────────────────────────────────────────────
# Optional fallback PAT used when a repo card has no per-repo PAT.
# The per-repo PAT (set via the Edit (pencil) icon on each repo card)
# is always preferred over this default.
#
# Required scopes:
#   • Classic PATs:        "repo"
#   • Fine-grained PATs:   "Contents: Read & Write" AND
#                          "Pull requests: Read & Write"
GITHUB_DEFAULT_PAT=

# ─── LLM Provider API Keys ────────────────────────────────────
# Add only the providers you actually use. The Settings → Agent Config
# UI lets you assign a specific provider+model to each agent.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ─── Default model assignments ────────────────────────────────
# Format: provider_name/model_id   e.g. openai/gpt-4o
# Used as a fallback when an agent has no model assigned in Settings.
SCANNER_AGENT_MODEL=openai/gpt-4o
FIXER_AGENT_MODEL=openai/gpt-4o
REVIEWER_AGENT_MODEL=openai/gpt-4o-mini
REPORTER_AGENT_MODEL=openai/gpt-4o-mini

# ─── Pipeline timeouts (seconds) ──────────────────────────────
# The orchestrator wraps the entire pipeline in asyncio.wait_for()
# with this budget; long-running scans will be cancelled cleanly
# and marked 'failed' with a timeout error.
PIPELINE_TOTAL_TIMEOUT_SECONDS=1200
PIPELINE_STAGE_TIMEOUT_SECONDS=600
SONAR_TASK_POLL_TIMEOUT_SECONDS=600